projection;
strict ( 2 );
use draft;

define behavior for zc_saleshdr48 alias header
use etag
{
  use create;
  use update;
  //    use delete;

  use action Activate;
  use action Edit;
  use action Resume;
  use action Discard;
  use action Prepare;

  use association _item { create; with draft; }
}

define behavior for zc_salesitem48 alias item
use etag
{
  use update;
  //    use delete;

  use association _header { with draft; }
}